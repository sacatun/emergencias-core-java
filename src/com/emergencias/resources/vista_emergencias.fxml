<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15"
      alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.emergencias.controlador.ControladorVistaEmergencias">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>

        <Label text="🚑 Sistema de Gestión de Emergencias" />

        <TextField fx:id="campoUbicacion" promptText="Ubicación" />
        <TextField fx:id="campoGravedad" promptText="Gravedad (0-10)" />
        <ComboBox fx:id="comboTipoAsistencia" promptText="Tipo de asistencia" />
        <TextField fx:id="campoMunicipio" promptText="Municipio" />

        <Button text="Procesar Emergencia" onAction="#procesarEmergencia" />

        <TextArea fx:id="areaResultado" prefWidth="600" prefHeight="300" wrapText="true" />

    </children>
</VBox>